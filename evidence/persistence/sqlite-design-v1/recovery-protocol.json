  "writer_ownership_protocol": {
    "record_location": "writer_ownership table, id=1 singleton row",
    "columns": {
      "token": "UUID string; NULL when unowned",
      "owner_epoch": "monotonic u64 incremented on each takeover",
      "lease_duration_ms": "renewal interval used to compute next lease_expires_at_unix_ms",
      "lease_expires_at_unix_ms": "persisted UTC millisecond expiry; stale when now_unix_ms >= lease_expires_at_unix_ms",
      "process_instance_id": "UUID generated once per adapter process instance; diagnostic only",
      "holder_pid": "optional diagnostic; not used for stale detection"
    },
    "acquisition_operation": "UPDATE writer_ownership SET ... WHERE id=1 AND (token IS NULL OR now_unix_ms >= lease_expires_at_unix_ms)",
    "renewal_policy": "on each authoritative command set lease_expires_at_unix_ms = now_unix_ms + lease_duration_ms",
    "normal_release": "UPDATE token=NULL WHERE token matches handle on close",
    "stale_detection": [
      "now_unix_ms >= lease_expires_at_unix_ms",
      "explicit operator/API stale_takeover after integrity_check"
    ],
    "takeover_authority": "new process after stale proof; integrity_check; epoch bump; new token",
    "race_handling": "SQLite transaction serializes ownership UPDATE; second acquirer gets writer-already-open",
    "split_brain_prevention": "only one non-expired token; epoch mismatch rejects stale handle commands",
    "recovery_after_process_crash": "lease expiry enables takeover; canonical state from SQLite only",
    "recovery_after_machine_reboot": "lease_expires_at_unix_ms may elapse during downtime; stale detected at open via UTC comparison after integrity_check",
    "lease_clock_policy": "persist lease_expires_at_unix_ms as UTC milliseconds; compare with SystemTime UTC at acquire/open; if wall clock jumps backward making expiry ambiguous, fail closed with lease-clock-ambiguous requiring ManualReviewRequired",
    "filesystem_limitations": "NFS or network FS may weaken lock semantics; record in 2D limitations",
    "prohibited": [
      "PID absence alone as universal stale test",
      "external lock file without SQLite transaction composition",
      "permanently orphanable token without expiry"
    ]
  },
  "duplication_protocol": {
    "name": "wal_safe_online_backup_duplication",
    "mechanism": "rusqlite backup::Backup::new / run_to_completion",
    "steps": [
      {
        "step": 1,
        "name": "source_writer_coordination",
        "operation": "Require source writable handle open; hold source Connection for backup"
      },
      {
        "step": 2,
        "name": "optional_wal_checkpoint",
        "operation": "PRAGMA wal_checkpoint(TRUNCATE) on source if policy requires quiesced WAL before backup"
      },
      {
        "step": 3,
        "name": "destination_creation",
        "operation": "create_dir; open temp destination Connection at session.db.tmp"
      },
      {
        "step": 4,
        "name": "backup_copy",
        "operation": "Backup API from source Connection to destination while source may remain writable"
      },
      {
        "step": 5,
        "name": "destination_integrity_check",
        "operation": "PRAGMA integrity_check on destination temp database; fail closed if not ok"
      },
      {
        "step": 6,
        "name": "identity_transformation",
        "operation": "BEGIN on destination; UPDATE session_meta SET value = ?1 WHERE key = 'session_id'; UPDATE session_meta SET value = ?2 WHERE key = 'duplicated_from'; clear writer_ownership; COMMIT"
      },
      {
        "step": 7,
        "name": "destination_semantic_validation",
        "operation": "assemble canonical state from destination tables; semantic oracle against independent expected before publish"
      },
      {
        "step": 8,
        "name": "destination_finalize",
        "operation": "PRAGMA wal_checkpoint(TRUNCATE) on destination; close destination Connection; assert no live session.db.tmp-wal or session.db.tmp-shm companions remain"
      },
      {
        "step": 9,
        "name": "atomic_publication",
        "operation": "rename closed session.db.tmp to session.db only after WAL companions quiesced; publish closed files only"
      },
      {
        "step": 10,
        "name": "post_publish_verification",
        "operation": "new adapter instance reopen published destination read-only; verify source unchanged via separate source reopen"
      }
    ],
    "wal_and_shm_treatment": "Backup API produces consistent snapshot into temp main file; identity COMMIT may create WAL companions on temp db; semantic validation occurs before publish; TRUNCATE checkpoint and close Connection before rename; do not rename main file while -wal/-shm companions are live; do not manually assemble source db+wal+shm triple copy",
    "identity_transformation": "in destination SQLite transaction after integrity_check and before semantic validation",
    "lineage_metadata": "session_meta.duplicated_from = source session_id",
    "failure_cleanup": "delete destination directory entirely; source never mutated",
    "source_immutability": "source canonical tables unchanged; verify by source reopen oracle",
    "destination_validation": "integrity_check plus independent semantic oracle on staged temp db before publish; post-publish reopen verification",
    "interrupted_duplication_recovery": "unpublished .tmp or partial dir deleted; no destination session identity registered",
    "acknowledgement_boundary": "duplicate_session returns Ok only after publish and post-publish verification complete",
    "prohibited": [
      "fs::copy session.db only",
      "copy db+wal+shm as ad hoc protocol",
      "JSON snapshot as duplication source",
      "publish before integrity_check",
      "publish before independent semantic validation",
      "self-oracle on adapter-returned state without reopen"
    ]
  },
